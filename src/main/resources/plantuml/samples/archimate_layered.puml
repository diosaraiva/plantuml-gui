@startuml
!pragma layout smetana
!include <archimate/Archimate>

title Archimate Full Layered View

' ---- Motivation ----
Motivation_Stakeholder(stakeholder, "Customer")
Motivation_Goal(goal, "Seamless Experience")
Motivation_Requirement(req, "Low Latency")

' ---- Strategy ----
Strategy_Capability(cap, "Digital Commerce")
Strategy_CourseOfAction(coa, "Platform Modernization")

' ---- Business ----
Business_Actor(buyer, "Online Buyer")
Business_Process(purchase, "Purchase Process")
Business_Service(orderSvc, "Order Service")
Business_Object(order, "Order")

' ---- Application ----
Application_Component(shop, "E-Commerce App")
Application_Component(payment, "Payment Gateway")
Application_Service(appSvc, "Shopping Service")
Application_DataObject(cart, "Shopping Cart")

' ---- Technology ----
Technology_Node(cloud, "AWS Cloud")
Technology_Device(cdn, "CDN Edge Node")
Technology_Artifact(image, "Docker Image")
Technology_Service(hosting, "Cloud Hosting")

' ---- Physical ----
Physical_Facility(dc, "Data Center")
Physical_Equipment(server, "Server Rack")

' ---- Implementation ----
Implementation_WorkPackage(wp, "Migration Sprint")
Implementation_Deliverable(release, "v2.0 Release")

' ---- Relationships across layers ----
Rel_Association(stakeholder, goal, "has")
Rel_Influence(goal, req, "drives")
Rel_Realization(cap, goal, "fulfills")
Rel_Realization(coa, cap, "realizes")
Rel_Assignment(buyer, purchase, "performs")
Rel_Realization(purchase, orderSvc, "realizes")
Rel_Access(purchase, order, "creates")
Rel_Serving(orderSvc, buyer, "serves")
Rel_Realization(shop, appSvc, "realizes")
Rel_Serving(appSvc, orderSvc, "supports")
Rel_Access(shop, cart, "manages")
Rel_Serving(payment, shop, "processes payment")
Rel_Serving(hosting, shop, "hosts")
Rel_Composition(cloud, cdn, "includes")
Rel_Realization(cloud, hosting, "provides")
Rel_Assignment(cloud, image, "deploys")
Rel_Composition(dc, server, "contains")
Rel_Assignment(server, cloud, "runs")
Rel_Realization(wp, release, "produces")
Rel_Realization(release, shop, "delivers")
@enduml
