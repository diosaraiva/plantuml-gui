@startuml
!pragma layout smetana
!include <archimate/Archimate>

title Archimate Motivation Layer

Motivation_Stakeholder(ceo, "CEO")
Motivation_Stakeholder(cto, "CTO")
Motivation_Stakeholder(customer, "Customer")
Motivation_Driver(growth, "Market Growth")
Motivation_Driver(efficiency, "Operational Efficiency")
Motivation_Assessment(gap, "Legacy System Gap")
Motivation_Assessment(risk, "Security Risk")
Motivation_Goal(digital, "Digital Transformation")
Motivation_Goal(reliability, "99.9% Uptime")
Motivation_Outcome(satisfaction, "Customer Satisfaction")
Motivation_Outcome(savings, "Cost Savings")
Motivation_Principle(security, "Security by Design")
Motivation_Principle(agile, "Agile Delivery")
Motivation_Requirement(compliance, "GDPR Compliance")
Motivation_Constraint(budget, "Budget Limit")
Motivation_Meaning(trust, "Customer Trust")
Motivation_Value(revenue, "Increased Revenue")

Rel_Association(ceo, growth, "concerned with")
