@startuml
!pragma layout smetana
!include <archimate/Archimate>

title Archimate Strategy Layer

Strategy_Resource(res1, "Human Resources")
Strategy_Resource(res2, "IT Budget")
Strategy_Capability(cap1, "Digital Transformation")
Strategy_Capability(cap2, "Data Analytics")
Strategy_CourseOfAction(coa1, "Cloud Migration Plan")
Strategy_CourseOfAction(coa2, "Data Platform Initiative")
Strategy_ValueStream(vs1, "Customer Onboarding")

